DATABASE_URL=""
JWT_SECRET=""
REFRESH_TOKEN_SECRET=""
PORT=3000
NODE_ENV="production"

# Flow Chile — obtén estas credenciales en app.flow.cl
FLOW_API_KEY=""
FLOW_SECRET=""
# IMPORTANTE: "sandbox" para pruebas, "production" para producción real
FLOW_ENV="production"
# URL pública del backend donde Flow enviará la confirmación de pago (POST)
FLOW_URL_CONFIRMATION="https://api.alala.cl/api/v1/pagos/confirmacion"
# URL del backend que recibirá el redirect del usuario (GET)
FLOW_URL_RETURN="https://api.alala.cl/api/v1/pagos/retorno"

# URL base del frontend
FRONTEND_URL="https://alala.cl"

# Google Drive API — contenido digital
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_CREDENTIALS_PATH="google-credentials.json"

# SMTP para emails transaccionales
# Configurar con las credenciales de contacto@alala.cl
# El remitente siempre será: "ALALA Chile" <contacto@alala.cl>
SMTP_HOST="mail.alala.cl"
SMTP_PORT=587
SMTP_USER="contacto@alala.cl"
SMTP_PASS=""
