generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  CREATOR
  ADMIN
}

enum CourseModalidad {
  presencial
  online
  hibrido
}

enum ContenidoDigitalStatus {
  borrador
  activo
  pausado
}

enum SolicitudRetiroEstado {
  pendiente
  procesado
  rechazado
}

enum MiniEbookTemplate {
  minimalista
  cinematografica
  poetica
  motivacional
}

model User {
  id                Int                @id @default(autoincrement())
  nombre            String
  email             String             @unique
  password          String
  role              UserRole           @default(STUDENT)
  verificado        Boolean            @default(false)
  activo            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  refreshTokens     RefreshToken[]
  matriculas        Enrollment[]
  compras           Venta[]            @relation("VentaComprador")
  misVentas         Venta[]            @relation("VentaInstructor")
  cursosCreados     Course[]
  saldo             InstructorSaldo?
  reviews           Review[]
  favorites         Favorite[]
  contenidosCreados ContenidoDigital[]
  comprasContenido  CompraContenido[]
  resenasContenido  ResenaContenido[]
  microContenidos   MicroContenido[]
  miniEbooks        MiniEbook[]
  creatorProfile    CreatorProfile?
  pagosRecibidos    PagoCreador[]
  siguiendo         UserFollow[]       @relation("Seguidor")
  seguidores        UserFollow[]       @relation("Seguido")
  comentarios       ArticleComment[]
  articulosFav      ArticleFavorite[]
  listas            UserList[]
  mensajesEnviados  Mensaje[]          @relation("MensajeRemitente")
  mensajesRecibidos Mensaje[]          @relation("MensajeDestinatario")
  eventosAnaliticos EventoAnalitico[]
  retiros           SolicitudRetiro[]
  retirosAdmin      SolicitudRetiro[]  @relation("SolicitudRetiroAdmin")
  pagosAdmin        PagoCreador[]      @relation("PagoCreadorAdmin")
  favoritesContenido FavoriteContenido[]
  favoritesMicroContenido FavoriteMicroContenido[]
  favoritesMiniEbook FavoriteMiniEbook[]

  @@index([email])
  @@index([role])
  @@index([activo])
  @@index([verificado])
}

model SiteConfig {
  clave     String   @id
  valor     String
  updatedAt DateTime @updatedAt
}

model PagoCreador {
  id          Int       @id @default(autoincrement())
  creatorId   Int
  creator     User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  monto       Int
  descripcion String?
  periodo     String?
  referencia  String?
  adminId     Int?
  admin       User?     @relation("PagoCreadorAdmin", fields: [adminId], references: [id])
  pagadoEn    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([creatorId])
  @@index([createdAt])
  @@index([adminId])
}

model SolicitudRetiro {
  id          Int                   @id @default(autoincrement())
  userId      Int
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  monto       Int
  estado      SolicitudRetiroEstado @default(pendiente)
  metodo      String?               // transferencia | otro
  cuenta      String?               // datos de cuenta bancaria
  respuesta   String?               // respuesta del admin
  procesadoEn DateTime?
  adminId     Int?
  admin       User?                 @relation("SolicitudRetiroAdmin", fields: [adminId], references: [id])
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId])
  @@index([estado])
  @@index([createdAt])
  @@index([adminId])
}

model CreatorProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombrePublico String
  bio           String?
  avatar        String?
  especialidad  String?
  sitioWeb      String?
  instagram     String?
  twitter       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RefLinkVisit {
  id        Int      @id @default(autoincrement())
  creatorId Int
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([creatorId])
  @@index([createdAt])
}

model Course {
  id                 Int          @id @default(autoincrement())
  titulo             String
  descripcion        String
  descripcionLarga   String?
  objetivos          String?
  contenidoPrograma  String?
  requisitos         String?
  nivel              String?
  duracion           String?
  materiales         String?
  beneficios         String?
  instructor         String
  instructorBio      String?
  instructorUserId   Int?
  instructorUser     User?        @relation(fields: [instructorUserId], references: [id])
  modulos            String?
  categoria          String
  precio             Int
  imagen             String?
  ciudad             String?
  lat                Float?
  lng                Float?
  modalidad          CourseModalidad?
  direccion          String?
  fechaInicio        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  alumnos            Enrollment[]
  ventas             Venta[]
  reviews            Review[]
  favorites          Favorite[]
  mensajes           Mensaje[]
  eventosAnaliticos  EventoAnalitico[]

  @@index([categoria])
  @@index([instructorUserId])
  @@index([createdAt])
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Venta {
  id                 Int      @id @default(autoincrement())
  flowToken          String   @unique
  flowOrder          String   @unique
  userId             Int
  courseId           Int
  instructorUserId   Int?
  monto              Int
  comisionPlataforma Int
  pagoInstructor     Int
  estado             String   @default("PENDIENTE")
  flowData           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation("VentaComprador", fields: [userId], references: [id], onDelete: Cascade)
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorUser     User?    @relation("VentaInstructor", fields: [instructorUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([instructorUserId])
  @@index([estado])
}

model InstructorSaldo {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  saldoPendiente Int      @default(0)
  saldoAcumulado Int      @default(0)
  saldoPagado    Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([expiresAt])
  @@index([userId])
}

model Review {
  id         Int      @id @default(autoincrement())
  cursoId    Int
  userId     Int
  rating     Int
  comentario String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  curso      Course   @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@unique([userId, cursoId])
  @@index([cursoId])
  @@index([userId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  curso     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model EventoAnalitico {
  id        Int      @id @default(autoincrement())
  tipo      String
  cursoId   Int?
  course    Course?  @relation(fields: [cursoId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tipo])
  @@index([cursoId])
  @@index([userId])
  @@index([createdAt])
}

model Mensaje {
  id             Int      @id @default(autoincrement())
  cursoId        Int
  remitenteId    Int
  destinatarioId Int
  texto          String
  leido          Boolean  @default(false)
  createdAt      DateTime @default(now())
  curso          Course   @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  remitente      User     @relation("MensajeRemitente", fields: [remitenteId], references: [id])
  destinatario   User     @relation("MensajeDestinatario", fields: [destinatarioId], references: [id])

  @@index([cursoId])
  @@index([remitenteId])
  @@index([destinatarioId])
  @@index([leido])
  @@index([createdAt])
}

model ContenidoDigital {
  id                 Int                 @id @default(autoincrement())
  titulo             String
  descripcion        String
  descripcionLarga   String?
  tipo               String // "microcurso" | "manual"
  categoria          String
  subcategoria       String?
  precio             Int
  precioOferta       Int?
  portadaUrl         String?
  pdfUrl             String?
  previewUrls        String[] // URLs de imágenes de preview (3 páginas)
  paginas            Int?
  tamanoMb           Float?
  idioma             String              @default("es")
  nivel              String? // principiante | intermedio | avanzado | todos
  creatorId          Int
  creator            User                @relation(fields: [creatorId], references: [id])
  status             ContenidoDigitalStatus @default(borrador)
  comisionPct        Float               @default(12.0) // cursos=12%, microcontenidos/ebooks=20%
  ventas             Int                 @default(0)
  rating             Float               @default(0)
  reviews            Int                 @default(0)
  indice             String? // JSON string con array de capítulos/secciones
  palabrasClave      String[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  compras            CompraContenido[]
  resenas            ResenaContenido[]
  comprasInvitado    CompraInvitado[]
  progresos          ProgresoLectura[]
  favoritesContenido FavoriteContenido[]

  @@index([tipo])
  @@index([categoria])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

model CompraContenido {
  id                 Int              @id @default(autoincrement())
  contenidoId        Int
  contenido          ContenidoDigital @relation(fields: [contenidoId], references: [id], onDelete: Cascade)
  userId             Int
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  monto              Int
  comisionPlataforma Int
  pagoCreador        Int
  estado             String           @default("completada") // pendiente | completada | reembolsada
  downloadUrl        String?
  flowToken          String?
  flowOrder          String?
  createdAt          DateTime         @default(now())

  @@unique([userId, contenidoId])
  @@index([flowToken])
  @@index([userId])
  @@index([contenidoId])
  @@index([estado])
}

model ResenaContenido {
  id          Int              @id @default(autoincrement())
  contenidoId Int
  contenido   ContenidoDigital @relation(fields: [contenidoId], references: [id], onDelete: Cascade)
  userId      Int
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int
  comentario  String
  createdAt   DateTime         @default(now())

  @@unique([userId, contenidoId])
  @@index([contenidoId])
  @@index([userId])
}

model Cupon {
  id              Int              @id @default(autoincrement())
  codigo          String           @unique
  creatorId       Int
  contenidoId     Int? // null = aplica a todo el catálogo del creador
  descuentoPct    Int // ej: 20 = 20%
  usosMaximos     Int              @default(100)
  usosActuales    Int              @default(0)
  activo          Boolean          @default(true)
  fechaExpiracion DateTime?
  createdAt       DateTime         @default(now())
  comprasInvitado CompraInvitado[]

  @@index([creatorId])
  @@index([contenidoId])
  @@index([activo])
  @@index([fechaExpiracion])
}

model CompraInvitado {
  id                 Int              @id @default(autoincrement())
  email              String
  nombre             String?
  contenidoId        Int
  contenido          ContenidoDigital @relation(fields: [contenidoId], references: [id], onDelete: Cascade)
  monto              Int
  comisionPlataforma Int
  pagoCreador        Int
  cuponId            Int?
  cupon              Cupon?           @relation(fields: [cuponId], references: [id])
  estado             String           @default("completada")
  downloadUrl        String?
  createdAt          DateTime         @default(now())

  @@index([email])
  @@index([contenidoId])
  @@index([estado])
}

model ProgresoLectura {
  id            Int              @id @default(autoincrement())
  userId        Int?
  emailInvitado String?
  contenidoId   Int
  paginaActual  Int              @default(1)
  porcentaje    Float            @default(0)
  updatedAt     DateTime         @updatedAt
  contenido     ContenidoDigital @relation(fields: [contenidoId], references: [id], onDelete: Cascade)

  @@unique([userId, contenidoId])
  @@unique([emailInvitado, contenidoId])
  @@index([contenidoId])
  @@index([userId])
}

model FavoriteContenido {
  id          Int              @id @default(autoincrement())
  userId      Int
  contenidoId Int
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contenido   ContenidoDigital @relation(fields: [contenidoId], references: [id], onDelete: Cascade)

  @@unique([userId, contenidoId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// MÓDULO MICROCONTENIDOS
// ═══════════════════════════════════════════════════════════

model MicroContenido {
  id            Int      @id @default(autoincrement())
  titulo        String
  descripcion   String?
  contenido     String   // texto completo del manual, instructivo o microtexto
  tipo          String   // "microtexto" | "manual" | "instructivo" | "minicurso"
  autorId       Int
  autor         User     @relation(fields: [autorId], references: [id])
  precio        Int?     // null = gratuito
  comisionPct   Float    @default(20.0) // % comisión plataforma
  ventas        Int      @default(0)
  publicado     Boolean  @default(true)
  portadaUrl    String?
  categoria     String   @default("General")
  palabrasClave String[]
  paginas       Int?
  lecturaMin    Int?     // tiempo estimado de lectura en minutos
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  compras         CompraMicroContenido[]
  resenas         ResenaMicroContenido[]
  favoritos       FavoriteMicroContenido[]
  progresos       ProgresoMicroContenido[]

  @@index([tipo])
  @@index([categoria])
  @@index([autorId])
  @@index([publicado])
}

model CompraMicroContenido {
  id                 Int             @id @default(autoincrement())
  microContenidoId   Int
  microContenido     MicroContenido  @relation(fields: [microContenidoId], references: [id], onDelete: Cascade)
  userId             Int?
  emailInvitado      String?
  monto              Int
  comisionPlataforma Int
  pagoCreador        Int
  estado             String          @default("completada")
  downloadUrl        String?
  flowToken          String?
  flowOrder          String?
  createdAt          DateTime        @default(now())

  @@unique([userId, microContenidoId])
  @@unique([emailInvitado, microContenidoId])
  @@index([flowToken])
}

model ResenaMicroContenido {
  id               Int            @id @default(autoincrement())
  microContenidoId Int
  microContenido   MicroContenido @relation(fields: [microContenidoId], references: [id], onDelete: Cascade)
  userId           Int
  rating           Int
  comentario       String
  createdAt        DateTime       @default(now())

  @@unique([userId, microContenidoId])
  @@index([microContenidoId])
}

model FavoriteMicroContenido {
  id               Int            @id @default(autoincrement())
  userId           Int
  microContenidoId Int
  microContenido   MicroContenido @relation(fields: [microContenidoId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([userId, microContenidoId])
  @@index([userId])
}

model ProgresoMicroContenido {
  id               Int            @id @default(autoincrement())
  userId           Int?
  emailInvitado    String?
  microContenidoId Int
  microContenido   MicroContenido @relation(fields: [microContenidoId], references: [id], onDelete: Cascade)
  porcentaje       Float          @default(0)
  leidoCompleto    Boolean        @default(false)
  updatedAt        DateTime       @updatedAt

  @@unique([userId, microContenidoId])
  @@unique([emailInvitado, microContenidoId])
}

// ═══════════════════════════════════════════════════════════
// MÓDULO MINI-EBOOKS
// ═══════════════════════════════════════════════════════════

model MiniEbook {
  id                Int      @id @default(autoincrement())
  titulo            String
  descripcion       String
  descripcionLarga  String?

  // Manuscrito
  manuscritoTexto   String?  // texto plano limpio
  manuscritoHtml    String?  // HTML maquetado según plantilla

  // Portada
  portadaUrl        String

  // Archivos generados
  epubUrl           String?
  pdfUrl            String?
  tamanoMb          Float?
  paginas           Int?
  palabras          Int?

  // Metadatos
  template          MiniEbookTemplate
  categoria         String   @default("General")
  palabrasClave     String[]
  idioma            String   @default("es")

  // Precio y ventas
  precio            Int
  precioOferta      Int?
  comisionPct       Float    @default(20.0)
  ventas            Int      @default(0)
  rating            Float    @default(0)
  reviews           Int      @default(0)

  // Estado
  status            String   @default("borrador") // borrador | activo | pausado

  // Autor
  autorId           Int
  autor             User     @relation(fields: [autorId], references: [id])

  // Índice generado automáticamente (JSON string)
  indice            String?

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  compras           CompraMiniEbook[]
  resenas           ResenaMiniEbook[]
  favoritos         FavoriteMiniEbook[]
  progresos         ProgresoMiniEbook[]

  @@index([status])
  @@index([categoria])
  @@index([autorId])
  @@index([template])
}

model CompraMiniEbook {
  id                 Int       @id @default(autoincrement())
  miniEbookId        Int
  miniEbook          MiniEbook @relation(fields: [miniEbookId], references: [id], onDelete: Cascade)
  userId             Int?
  emailInvitado      String?
  monto              Int
  comisionPlataforma Int
  pagoCreador        Int
  estado             String    @default("completada")
  downloadUrl        String?
  flowToken          String?
  flowOrder          String?
  createdAt          DateTime  @default(now())

  @@unique([userId, miniEbookId])
  @@unique([emailInvitado, miniEbookId])
  @@index([flowToken])
}

model ResenaMiniEbook {
  id          Int       @id @default(autoincrement())
  miniEbookId Int
  miniEbook   MiniEbook @relation(fields: [miniEbookId], references: [id], onDelete: Cascade)
  userId      Int
  rating      Int
  comentario  String
  createdAt   DateTime  @default(now())

  @@unique([userId, miniEbookId])
  @@index([miniEbookId])
}

model FavoriteMiniEbook {
  id          Int       @id @default(autoincrement())
  userId      Int
  miniEbookId Int
  miniEbook   MiniEbook @relation(fields: [miniEbookId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, miniEbookId])
  @@index([userId])
}

model ProgresoMiniEbook {
  id            Int       @id @default(autoincrement())
  userId        Int?
  emailInvitado String?
  miniEbookId   Int
  miniEbook     MiniEbook @relation(fields: [miniEbookId], references: [id], onDelete: Cascade)
  porcentaje    Float     @default(0)
  leidoCompleto Boolean   @default(false)
  updatedAt     DateTime  @updatedAt

  @@unique([userId, miniEbookId])
  @@unique([emailInvitado, miniEbookId])
}

// ═══════════════════════════════════════════════════════════
// MÓDULO REVISTA EDITORIAL
// ═══════════════════════════════════════════════════════════

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([activo])
}

model UserFollow {
  id         Int      @id @default(autoincrement())
  seguidorId Int
  seguidor   User     @relation("Seguidor", fields: [seguidorId], references: [id], onDelete: Cascade)
  seguidoId  Int
  seguido    User     @relation("Seguido", fields: [seguidoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([seguidorId, seguidoId])
  @@index([seguidorId])
  @@index([seguidoId])
}

model ArticleComment {
  id          Int      @id @default(autoincrement())
  articuloId  String   // ID del artículo en JSON (slug)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contenido   String
  aprobado    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articuloId])
  @@index([userId])
  @@index([aprobado])
  @@index([createdAt])
}

model ArticleFavorite {
  id         Int      @id @default(autoincrement())
  articuloId String   // ID del artículo en JSON (slug)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, articuloId])
  @@index([userId])
  @@index([articuloId])
}

model UserList {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  publica     Boolean        @default(false)
  items       UserListItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
}

model UserListItem {
  id         Int      @id @default(autoincrement())
  listaId    Int
  lista      UserList @relation(fields: [listaId], references: [id], onDelete: Cascade)
  tipo       String   // "articulo" | "curso" | "contenido"
  referenciaId String // ID del recurso
  createdAt  DateTime @default(now())

  @@unique([listaId, tipo, referenciaId])
  @@index([listaId])
}
