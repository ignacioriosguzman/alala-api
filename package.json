{
  "name": "alala-api",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "prisma db push --skip-generate && node src/server.js",
    "build": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "seed": "node scripts/seed-microcontenidos.js",
    "seed:check": "node -e \"import('./scripts/seed-microcontenidos.js').catch(e => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.7.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "prisma": "^5.13.0",
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
